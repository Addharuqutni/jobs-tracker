{
  "name": "jobs",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server/api/src/index.ts",
    "dev:all": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev\"",
    "dev:scraper": "tsx server/scraper/src/index.ts --cron",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx src/ server/",
    "format": "prettier --write src/ server/",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test",
    "test:coverage": "c8 --check-coverage --per-file --statements=35 --branches=35 --functions=35 --lines=35 --reporter=text --reporter=html --reporter=lcov --include=server/api/src/lib/validation.ts --include=server/db/src/queries/analytics-calculation.ts --include=server/scraper/src/adapters/*.ts --include=server/scraper/src/core/dedup.ts --include=server/scraper/src/sidecar/python-sidecar.ts --include=server/scraper/src/utils/json-extract.ts --include=server/scraper/src/utils/url.ts npm test",
    "scrape": "tsx server/scraper/src/index.ts",
    "scrape:once": "tsx server/scraper/src/index.ts --once",
    "diagnose": "tsx server/scraper/src/diagnose.ts",
    "scrape:experiment": "server\\scraper\\experiments\\.venv\\Scripts\\python.exe server\\scraper\\experiments\\benchmark.py",
    "scrape:experiment:jobstreet": "npm run scrape:experiment -- --source jobstreet --keyword \"react developer\" --pages 1 --runs 1",
    "scrape:experiment:linkedin": "npm run scrape:experiment -- --source linkedin --keyword \"react developer\" --pages 1 --runs 1",
    "scrape:compare-engines": "tsx server/scraper/src/compare-engines.ts",
    "db:migrate": "tsx server/db/src/migrate.ts",
    "db:seed": "tsx server/db/src/seed.ts"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^16.6.0",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.0",
    "lucide-react": "^0.400.0",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^22.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.24.0",
    "recharts": "^2.12.0",
    "string-similarity-js": "^2.1.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "c8": "^11.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.39",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.0",
    "typescript": "^5.9.3",
    "vite": "^5.3.0"
  }
}
