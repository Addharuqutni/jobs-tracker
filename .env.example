PORT=3001
HOST=127.0.0.1
DB_PATH=./data/jobs.db
SCRAPER_CRON=0 */6 * * *
SCRAPER_DELAY_MIN_MS=1000
SCRAPER_DELAY_MAX_MS=5000
SCRAPER_MAX_PAGES=5
SCRAPER_ENGINE=hybrid
SCRAPER_PYTHON_TOOL=auto
SCRAPER_PYTHON_TIMEOUT_MS=120000
# Queue (2c4g: concurrency=1)
SCRAPER_CONCURRENCY=1
SCRAPER_QUEUE_MAX=10
SCRAPER_RESULT_TTL_MS=900000
SCRAPER_RESULT_MAX=50
PYTHON_EXECUTABLE=./server/scraper/experiments/.venv/Scripts/python.exe
# Puppeteer fallback (used when a site blocks plain HTTP with 403/429).
# On Linux VPS set this to the Chrome binary path, e.g. /usr/bin/google-chrome-stable.
# Leave unset to auto-detect common locations (Windows/Linux/macOS).
PUPPETEER_EXECUTABLE_PATH=
VITE_API_URL=http://localhost:3001/api
LOG_LEVEL=info

# CV Review AI (OpenRouter / OpenAI-compatible)
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=google/gemini-2.0-flash-exp:free
